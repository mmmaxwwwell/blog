---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const { title, description, date, updated, category, tags, heroImage } = post.data;
---
<PostLayout title={title} description={description} date={date} updated={updated} category={category} tags={tags} heroImage={heroImage}>
  <Content />

  <!-- Prev/Next navigation -->
  {(prevPost || nextPost) && (
    <nav class="mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-border flex flex-col sm:flex-row justify-between gap-4">
      {nextPost ? (
        <a href={`/${nextPost.id}/`} class="group flex flex-col sm:max-w-[45%]">
          <span class="text-xs text-text-muted mb-1">&larr; Older</span>
          <span class="text-sm font-medium underline decoration-transparent group-hover:decoration-current transition-all">{nextPost.data.title}</span>
        </a>
      ) : <div />}
      {prevPost ? (
        <a href={`/${prevPost.id}/`} class="group flex flex-col sm:items-end sm:max-w-[45%] sm:ml-auto">
          <span class="text-xs text-text-muted mb-1">Newer &rarr;</span>
          <span class="text-sm font-medium underline decoration-transparent group-hover:decoration-current transition-all">{prevPost.data.title}</span>
        </a>
      ) : <div />}
    </nav>
  )}
</PostLayout>
