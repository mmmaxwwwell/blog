---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---
{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag}/`}
        class="text-xs px-2 py-0.5 rounded-full border border-border bg-bg-surface text-text-muted hover:text-[var(--accent-pink)] hover:border-[var(--accent-pink)] transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
)}
